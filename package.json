{
  "name": "ryoku",
  "version": "1.1.0",
  "description": "RYOKU - Anime streaming app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.ryoku.anime",
    "productName": "RYOKU",
    "copyright": "RYOKU",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerSidebar": "assets/installer-sidebar.bmp",
      "installerHeader": "assets/installer-header.bmp",
      "shortcutName": "RYOKU",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh",
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "main.js",
      "splash.js",
      "extractors/**/*",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "FaxTheGhoul",
      "repo": "ryoku",
      "private": true
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "axios": "^0.27.2",
    "cheerio": "^1.0.0-rc.12",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.3.0"
  }
}
